{
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "atlas",
    "version": "0.1.6"
  },
  "tauri": {
    "allowlist": {
      "all": true
    },
    "windows": [
      {
        "title": "Atlas SSH Client",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "fileDropEnabled": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    },
    "bundle": {
      "active": true,
      "targets": ["nsis"],
      "identifier": "com.atlas.app",
      "icon": ["icons/icon.ico"]
    }
  }
}
